#!/usr/bin/env bash
# Simple commit message validation using commitlint

echo "🚀 Running commit message validation..."

# pnpm must be installed
if ! command -v pnpm >/dev/null 2>&1; then
  echo "❌ Error: pnpm is not installed!" >&2
  exit 1
fi

COMMIT_MSG_FILE="$1"
COMMIT_MSG_CONTENT=$(cat "$COMMIT_MSG_FILE")

# Optional: Skip system commits (Merge, Revert, fixup, squash)
if echo "$COMMIT_MSG_CONTENT" | grep -qE "^(Merge|Revert|fixup!|squash!)"; then
  echo "ℹ️ Detected system commit. Skipping commitlint."
  exit 0
fi

# Run commitlint via pnpm exec
pnpm exec commitlint --config commitlint.config.mjs --edit "$COMMIT_MSG_FILE"
STATUS=$?

if [ $STATUS -ne 0 ]; then
  echo "❌ Commit message validation failed (commitlint)."
  exit 1
fi

echo "✅ Commit message is valid!"
exit 0
